generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ApiFamily {
  CODEXAI
  CLAUDE
  GEMINI
  DEEPSEEK
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum ProviderStatus {
  ACTIVE
  DISABLED
}

enum CreditLedgerType {
  PURCHASE
  USAGE
  REFUND
  ADJUSTMENT
  EXPIRE
  ADMIN_GRANT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  role         UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys        ApiKey[]
  orders         Order[]
  creditBuckets  CreditBucket[]
  usageLogs      UsageLog[]
  ledgers        CreditLedger[]
  supportTickets SupportTicket[]
  oauthAccounts  OAuthAccount[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  lockedAt       DateTime?
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  NORMAL
  HIGH
  URGENT
}

model SupportTicket {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  name     String
  email    String
  category String
  priority TicketPriority @default(NORMAL)
  subject  String
  message  String         @db.Text

  orderCode    String?
  apiKeyPrefix String?

  status TicketStatus @default(OPEN)

  adminNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Product {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  apiFamily ApiFamily

  tier         String @default("Mini")
  credits      BigInt
  durationDays Int?
  priceVnd     Int
  apiKeyLimit  Int    @default(1)

  allowedModels    String[]
  allowedReasoning String[]

  isPopular     Boolean @default(false)
  isActive      Boolean @default(true)
  isContactOnly Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  creditBuckets CreditBucket[]

  @@index([apiFamily])
  @@index([tier])
  @@index([isActive])
}

model Order {
  id        String @id @default(cuid())
  orderCode String @unique

  userId    String
  productId String

  status    OrderStatus @default(PENDING)
  amountVnd Int

  paidAt      DateTime?
  cancelledAt DateTime?
  expiredAt   DateTime?

  payosOrderCode     BigInt?   @unique
  payosPaymentLinkId String?
  payosCheckoutUrl   String?
  payosQrCode        String?   @db.Text
  payosStatus        String?
  paymentExpiredAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

model CreditBucket {
  id        String  @id @default(cuid())
  userId    String
  productId String?

  apiFamily ApiFamily

  creditsTotal     BigInt
  creditsRemaining BigInt

  apiKeyLimit Int @default(1)

  allowedModels    String[]
  allowedReasoning String[]

  startsAt  DateTime  @default(now())
  expiresAt DateTime?

  isActive Boolean @default(true)

  lowCreditsAlertSent   Boolean @default(false)
  expiringSoonAlertSent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  apiKeys   ApiKey[]
  usageLogs UsageLog[]
  ledgers   CreditLedger[]

  @@index([userId])
  @@index([productId])
  @@index([apiFamily])
  @@index([isActive])
  @@index([expiresAt])
}

model ApiKey {
  id String @id @default(cuid())

  userId         String
  creditBucketId String?

  name      String
  apiFamily ApiFamily

  keyHash      String  @unique
  keyPrefix    String
  encryptedKey String?

  isActive Boolean @default(true)

  lastUsedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditBucket CreditBucket? @relation(fields: [creditBucketId], references: [id])
  usageLogs    UsageLog[]

  @@index([userId])
  @@index([creditBucketId])
  @@index([apiFamily])
  @@index([isActive])
}

model AiProvider {
  id              String    @id @default(cuid())
  name            String
  apiFamily       ApiFamily
  baseUrl         String
  encryptedApiKey String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  models AiModel[]
}

model AiModel {
  id               String    @id @default(cuid())
  publicName       String    @unique
  apiFamily        ApiFamily
  providerId       String
  upstreamModel    String
  inputCreditRate  Decimal   @default(1)
  outputCreditRate Decimal   @default(1)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([apiFamily])
  @@index([providerId])
  @@index([isActive])
}

model UsageLog {
  id String @id @default(cuid())

  userId         String
  apiKeyId       String?
  creditBucketId String?

  apiFamily ApiFamily
  model     String
  endpoint  String

  inputTokens  Int @default(0)
  outputTokens Int @default(0)
  cachedTokens Int @default(0)
  totalTokens  Int @default(0)

  creditsCharged BigInt @default(0)

  status       String  @default("SUCCESS")
  errorCode    String?
  errorMessage String?
  httpStatus   Int?
  creditsUsed  Int     @default(0)

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey       ApiKey?       @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  creditBucket CreditBucket? @relation(fields: [creditBucketId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([apiKeyId])
  @@index([creditBucketId])
  @@index([apiFamily])
  @@index([status])
  @@index([createdAt])
}

model CreditLedger {
  id String @id @default(cuid())

  userId         String
  creditBucketId String?

  apiFamily ApiFamily
  type      CreditLedgerType

  amount       BigInt
  balanceAfter BigInt

  reason      String?
  note        String?
  referenceId String?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditBucket CreditBucket? @relation(fields: [creditBucketId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([creditBucketId])
  @@index([apiFamily])
  @@index([type])
  @@index([createdAt])
}

model PaymentProviderSetting {
  id                   String   @id @default(cuid())
  provider             String   @unique
  clientId             String?
  encryptedApiKey      String?
  encryptedChecksumKey String?
  environment          String   @default("production")
  isActive             Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  linkedAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model AuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser User @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String?
  roleTarget String?
  type       String
  title      String
  message    String
  href       String?
  isRead     Boolean   @default(false)
  metadata   Json?
  dedupeKey  String?
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId])
  @@index([roleTarget])
  @@index([isRead])
  @@index([createdAt])
  @@index([dedupeKey])
}
