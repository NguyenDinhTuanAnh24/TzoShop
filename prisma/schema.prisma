generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ApiFamily {
  CODEXAI
  CLAUDE
  GEMINI
  DEEPSEEK
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum ProviderStatus {
  ACTIVE
  DISABLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  role         UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys       ApiKey[]
  orders        Order[]
  creditBuckets CreditBucket[]
  usageLogs     UsageLog[]
}

model Product {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  apiFamily    ApiFamily
  credits      BigInt
  durationDays Int
  priceVnd     Int

  allowedModels    String[]
  allowedReasoning String[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  creditBuckets CreditBucket[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  productId String

  status    OrderStatus @default(PENDING)
  amountVnd Int

  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model CreditBucket {
  id        String    @id @default(cuid())
  userId    String
  productId String?
  apiFamily ApiFamily

  creditsTotal     BigInt
  creditsRemaining BigInt

  allowedModels    String[]
  allowedReasoning String[]

  expiresAt DateTime
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model ApiKey {
  id     String @id @default(cuid())
  userId String

  name      String
  keyHash   String  @unique
  keyPrefix String
  isActive  Boolean @default(true)

  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs UsageLog[]
}

model AiModel {
  id           String    @id @default(cuid())
  publicName   String    @unique
  upstreamName String
  apiFamily    ApiFamily

  inputCreditMultiplier  Float @default(1)
  outputCreditMultiplier Float @default(1)
  cacheCreditMultiplier  Float @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderKey {
  id        String    @id @default(cuid())
  name      String
  apiFamily ApiFamily

  baseUrl      String
  encryptedKey String

  status   ProviderStatus @default(ACTIVE)
  priority Int            @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UsageLog {
  id       String  @id @default(cuid())
  userId   String
  apiKeyId String?

  apiFamily ApiFamily
  model     String
  endpoint  String

  inputTokens  Int @default(0)
  outputTokens Int @default(0)
  cachedTokens Int @default(0)
  totalTokens  Int @default(0)

  creditsCharged BigInt @default(0)

  status       String
  errorMessage String?

  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
}